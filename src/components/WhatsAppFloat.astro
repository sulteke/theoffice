---
/**
 * Floating WhatsApp button (bottom-right). Shown on tablet/desktop; on phones
 * the sticky MobileActionBar covers this action instead.
 */
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { waLink } from '../data/business';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const waHref = waLink(t('wa.general'));
---

<a
  href={waHref}
  target="_blank"
  rel="noopener"
  aria-label={t('cta.whatsapp')}
  class="fixed bottom-6 right-6 z-40 hidden h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-ink shadow-card transition-transform hover:scale-105 md:flex"
>
  <Icon name="whatsapp" size={30} />
</a>
