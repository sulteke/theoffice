---
/**
 * ПРАЗДНИКИ (Celebrations) — a continuously scrolling strip of photos from
 * parties the venue has hosted (social proof), plus a WhatsApp "book a party"
 * CTA. Slides & captions are edited in src/data/celebrations.ts.
 *
 * The strip auto-scrolls horizontally (CSS marquee, no JS), pauses on hover,
 * and stops for visitors who prefer reduced motion (they can scroll it by hand).
 */
import { Image } from 'astro:assets';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { waLink } from '../data/business';
import { celebrations } from '../data/celebrations';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const partyHref = waLink(t('wa.party'));

// Duplicate the list so the marquee can loop seamlessly.
const strip = [...celebrations, ...celebrations];
---

<section id="events" class="scroll-mt-24 overflow-hidden border-t border-white/5 bg-navy-elevated/40 py-20 md:py-28">
  <div class="container-x">
    <div class="max-w-2xl" data-reveal>
      <p class="kicker">{t('events.kicker')}</p>
      <h2 class="section-title mt-3">{t('events.title')}</h2>
      <p class="mt-5 text-muted">{t('events.intro')}</p>
    </div>
  </div>

  <!-- Continuously scrolling strip of past celebrations -->
  <div
    class="celeb-viewport mt-10 overflow-hidden"
    data-reveal
    role="group"
    aria-roledescription="carousel"
    aria-label={t('events.hostedLabel')}
  >
    <div class="celeb-track flex w-max">
      {strip.map((c, i) => (
        <figure
          class="relative mr-4 h-60 w-72 shrink-0 overflow-hidden rounded-2xl border border-white/10 shadow-card sm:h-72 sm:w-96"
          aria-hidden={i >= celebrations.length ? 'true' : 'false'}
        >
          <Image
            src={c.src}
            alt={i < celebrations.length ? c.caption[lang] : ''}
            widths={[320, 480, 640]}
            sizes="384px"
            loading="lazy"
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/90 via-navy-deep/20 to-transparent"></div>
          <figcaption class="absolute inset-x-0 bottom-0 p-4">
            <span class="kicker text-[0.7rem]">{t('events.hostedLabel')}</span>
            <p class="mt-0.5 font-serif text-xl font-bold text-ink">{c.caption[lang]}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>

  <div class="container-x">
    <!-- Book a private party CTA -->
    <div class="mt-12 flex flex-col items-center gap-3 rounded-2xl border border-gold/20 bg-gold/5 p-8 text-center" data-reveal>
      <p class="max-w-xl text-muted">{t('events.private.desc')}</p>
      <a href={partyHref} target="_blank" rel="noopener" class="btn btn-primary mt-1">
        <Icon name="whatsapp" size={20} />
        {t('events.bookParty')}
      </a>
    </div>
  </div>
</section>

<style>
  /* Continuous horizontal auto-scroll. Two copies of the list sit side by side
     and the track slides left by exactly one copy (-50%), then loops. */
  .celeb-track {
    animation: celeb-scroll 36s linear infinite;
  }
  .celeb-viewport:hover .celeb-track {
    animation-play-state: paused;
  }
  @keyframes celeb-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .celeb-track { animation: none; }
    .celeb-viewport { overflow-x: auto; }
  }
</style>
