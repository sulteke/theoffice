---
/**
 * CART / LIVE PRE-ORDER CALCULATOR.
 * - Menu & hookah items have a "+" button (data-add-to-cart) that drops the
 *   item in here. The cart adds up the total live and is saved in the browser.
 * - "Оформить предзаказ" sends the whole order to WhatsApp.
 * - The reservation form can optionally attach this order (see Reservation.astro).
 *
 * Included once in BaseLayout, so the cart works on every page.
 * The header's cart button (data-cart-open) and its badge (data-cart-count)
 * are wired up by the script below.
 */
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { business } from '../data/business';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div
  id="office-cart"
  data-wa={business.whatsapp}
  data-hello={t('cart.waHello')}
  data-total-label={t('cart.total')}
  data-remove-label={t('cart.remove')}
>
  <!-- Backdrop -->
  <div id="cart-backdrop" class="fixed inset-0 z-[85] hidden bg-navy-deep/70 backdrop-blur-sm"></div>

  <!-- Slide-over panel -->
  <aside
    id="cart-panel"
    class="fixed right-0 top-0 z-[90] flex h-[100dvh] w-full max-w-md translate-x-full flex-col bg-navy-elevated shadow-card transition-transform duration-300"
    role="dialog"
    aria-modal="true"
    aria-label={t('cart.title')}
    aria-hidden="true"
  >
    <header class="flex items-center justify-between border-b border-white/10 p-5">
      <h2 class="font-serif text-xl font-bold text-ink">{t('cart.title')}</h2>
      <button id="cart-close" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/5 text-ink hover:bg-white/10" aria-label={t('gallery.close')}>
        <Icon name="close" size={24} />
      </button>
    </header>

    <div class="flex-1 overflow-y-auto p-5">
      <ul id="cart-lines" class="space-y-3"></ul>
      <p id="cart-empty" class="py-10 text-center text-sm text-muted">{t('cart.empty')}</p>
    </div>

    <footer class="border-t border-white/10 p-5">
      <div class="flex items-baseline justify-between">
        <span class="text-sm uppercase tracking-widest text-muted">{t('cart.total')}</span>
        <span id="cart-total" class="font-serif text-2xl font-bold text-gold">0 ₸</span>
      </div>
      <p class="mt-2 text-xs text-muted">{t('cart.note')}</p>
      <a id="cart-checkout" href="#" target="_blank" rel="noopener" class="btn btn-primary mt-4 w-full aria-disabled:pointer-events-none aria-disabled:opacity-50" aria-disabled="true">
        <Icon name="whatsapp" size={20} />
        {t('cart.checkout')}
      </a>
      <button id="cart-clear" type="button" class="mt-2 inline-flex w-full items-center justify-center gap-1.5 py-2 text-sm text-muted transition-colors hover:text-ink">
        <Icon name="trash" size={16} />
        {t('cart.clear')}
      </button>
    </footer>
  </aside>

  <!-- "Added" toast -->
  <div id="cart-toast" class="pointer-events-none fixed bottom-24 left-1/2 z-[95] hidden -translate-x-1/2 rounded-full bg-gold px-4 py-2 text-sm font-medium text-navy-base shadow-gold">
    {t('cart.added')}
  </div>
</div>

<script>
  // ----------------------------------------------------------------------
  //  Cart state (persisted in the browser). Exposed as window.OfficeCart so
  //  the reservation form can read the current order on submit.
  // ----------------------------------------------------------------------
  type Line = { id: string; name: string; price: number; qty: number };
  const KEY = 'office-cart-v1';
  const root = document.getElementById('office-cart');
  const wa = root?.dataset.wa || '';
  const hello = root?.dataset.hello || '';
  const totalLabel = root?.dataset.totalLabel || 'Итого';
  const removeLabel = root?.dataset.removeLabel || 'Удалить';

  let items: Line[] = load();

  function load(): Line[] {
    try {
      const raw = JSON.parse(localStorage.getItem(KEY) || '[]');
      return Array.isArray(raw) ? raw : [];
    } catch {
      return [];
    }
  }
  function persist() {
    localStorage.setItem(KEY, JSON.stringify(items));
    render();
  }
  const money = (n: number) => `${n.toLocaleString('ru-RU')} ₸`;
  const total = () => items.reduce((s, i) => s + i.price * i.qty, 0);
  const count = () => items.reduce((s, i) => s + i.qty, 0);

  function add(id: string, name: string, price: number) {
    const found = items.find((i) => i.id === id);
    if (found) found.qty += 1;
    else items.push({ id, name, price, qty: 1 });
    persist();
    toast();
  }
  function setQty(id: string, qty: number) {
    const it = items.find((i) => i.id === id);
    if (!it) return;
    it.qty = qty;
    if (it.qty <= 0) items = items.filter((i) => i.id !== id);
    persist();
  }
  function clear() {
    items = [];
    persist();
  }

  // --- WhatsApp order text (used by the cart + the reservation form) ---
  function orderLines(): string {
    return items.map((i) => `• ${i.name} × ${i.qty} — ${money(i.price * i.qty)}`).join('\n');
  }
  function orderMessage(): string {
    return `${hello}\n${orderLines()}\n${totalLabel}: ${money(total())}`;
  }

  // --- Panel open/close ---
  const backdrop = document.getElementById('cart-backdrop');
  const panel = document.getElementById('cart-panel');
  let lastFocus: HTMLElement | null = null;

  function open() {
    lastFocus = document.activeElement as HTMLElement;
    backdrop?.classList.remove('hidden');
    panel?.classList.remove('translate-x-full');
    panel?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    document.getElementById('cart-close')?.focus();
  }
  function close() {
    backdrop?.classList.add('hidden');
    panel?.classList.add('translate-x-full');
    panel?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  // --- Toast feedback on add ---
  let toastTimer: number | undefined;
  function toast() {
    const el = document.getElementById('cart-toast');
    if (!el) return;
    el.classList.remove('hidden');
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => el.classList.add('hidden'), 1500);
  }

  // --- Render the panel + badges ---
  function render() {
    const linesEl = document.getElementById('cart-lines');
    const emptyEl = document.getElementById('cart-empty');
    const totalEl = document.getElementById('cart-total');
    const checkout = document.getElementById('cart-checkout') as HTMLAnchorElement | null;

    if (totalEl) totalEl.textContent = money(total());

    // Header / anywhere badges
    document.querySelectorAll<HTMLElement>('[data-cart-count]').forEach((b) => {
      b.textContent = String(count());
      b.classList.toggle('hidden', count() === 0);
    });

    if (linesEl) {
      linesEl.innerHTML = items
        .map(
          (i) => `
        <li class="flex items-center gap-3" data-line="${i.id}">
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm text-ink">${i.name}</p>
            <p class="text-xs text-muted">${money(i.price)}</p>
          </div>
          <div class="flex items-center gap-1.5">
            <button type="button" data-dec="${i.id}" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/15 text-ink hover:border-gold" aria-label="−">−</button>
            <span class="w-6 text-center text-sm tabular-nums text-ink">${i.qty}</span>
            <button type="button" data-inc="${i.id}" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/15 text-ink hover:border-gold" aria-label="+">+</button>
          </div>
          <span class="w-20 shrink-0 text-right text-sm font-medium text-gold">${money(i.price * i.qty)}</span>
          <button type="button" data-del="${i.id}" class="text-muted hover:text-ink" aria-label="${removeLabel}">✕</button>
        </li>`
        )
        .join('');
    }
    emptyEl?.classList.toggle('hidden', items.length > 0);
    if (checkout) {
      if (items.length > 0) {
        checkout.href = `https://wa.me/${wa}?text=${encodeURIComponent(orderMessage())}`;
        checkout.setAttribute('aria-disabled', 'false');
      } else {
        checkout.href = '#';
        checkout.setAttribute('aria-disabled', 'true');
      }
    }
  }

  // --- Wire up DOM ---
  document.querySelectorAll<HTMLElement>('[data-add-to-cart]').forEach((btn) => {
    btn.addEventListener('click', () => {
      add(btn.dataset.id || '', btn.dataset.name || '', Number(btn.dataset.price || 0));
    });
  });
  document.querySelectorAll<HTMLElement>('[data-cart-open]').forEach((b) =>
    b.addEventListener('click', open)
  );
  document.getElementById('cart-close')?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);
  document.getElementById('cart-clear')?.addEventListener('click', clear);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel?.getAttribute('aria-hidden') === 'false') close();
  });
  // Delegate qty / delete clicks inside the lines list.
  document.getElementById('cart-lines')?.addEventListener('click', (e) => {
    const el = e.target as HTMLElement;
    const inc = el.closest<HTMLElement>('[data-inc]');
    const dec = el.closest<HTMLElement>('[data-dec]');
    const del = el.closest<HTMLElement>('[data-del]');
    if (inc) add2(inc.dataset.inc!, 1);
    else if (dec) add2(dec.dataset.dec!, -1);
    else if (del) setQty(del.dataset.del!, 0);
  });
  function add2(id: string, delta: number) {
    const it = items.find((i) => i.id === id);
    if (it) setQty(id, it.qty + delta);
  }

  // Expose for the reservation form.
  (window as any).OfficeCart = {
    getItems: () => items.slice(),
    total,
    count,
    orderLines,
    money,
    open,
  };

  render();
</script>
