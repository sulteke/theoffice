---
/**
 * Inline SVG icons (no external requests). Use:  <Icon name="music" />
 * Color follows the surrounding text color (currentColor); size via class.
 */
interface Props {
  name: string;
  class?: string;
  size?: number;
}
const { name, class: className = '', size = 24 } = Astro.props;
const stroke = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.7',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  'aria-hidden': 'true',
};
const fill = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'currentColor',
  'aria-hidden': 'true',
};
